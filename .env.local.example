NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# === Email transaccional (Gmail SMTP) ===
# Necesita una "Contraseña de aplicación" de Google (no la contraseña normal):
# https://myaccount.google.com/apppasswords  (requiere 2FA activada)
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=Skarbarber
# Email donde se notifican TODAS las reservas mientras no haya cuentas reales por barbero:
BARBERO_EMAIL_DEFAULT=tu_correo@gmail.com
